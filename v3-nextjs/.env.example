# Template for v3's environment. Copy it to a real .env, which stays gitignored:
#   cp .env.example .env
#
# DATABASE_URL points Prisma at the SQLite likes backend. The default below is a
# local file path (not a secret) — fine to keep as-is for local dev. Put anything
# sensitive in .env.local instead, never in a tracked file.
DATABASE_URL="file:./dev.db"
